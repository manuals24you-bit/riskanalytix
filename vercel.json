{
  "version": 2,
  "builds": [
    {
      "src": "frontend/api/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "npm install",
        "buildCommand": "npm run build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "frontend/api/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/index.html"
    }
  ]
}